{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": true,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "forest",
          "name": "Forest",
          "color": "#0b3b2e"
        },
        {
          "slug": "ink",
          "name": "Ink",
          "color": "#163328"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        },
        {
          "slug": "mist",
          "name": "Mist",
          "color": "#f4f6f2"
        }
      ]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1360px"
    },
    "spacing": {
      "blockGap": "0",
      "units": ["px", "%", "em", "rem", "vh", "vw"]
    },
    "typography": {
      "fluid": true
    }
  },
  "styles": {
    "css": ".wp-site-blocks{padding-top:0;padding-bottom:0;}.wp-block-template-part,.wp-block-group,.wp-block-html{margin-block-start:0;margin-block-end:0;}"
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
